{
  "name": "safenetfresh",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start -c --lan",
    "start:tunnel": "expo start -c --tunnel",
    "start:go": "expo start -c",
    "clean": "expo start --clear",
    "postinstall": "node -e \"console.log('Postinstall note: run npx expo start --clear if you see stale UTF-8 cache output')\"",
    "android": "expo start -c --lan --android",
    "ios": "expo start -c --lan --ios",
    "web": "expo start --web",
    "export:web": "expo export --platform web",
    "build:web": "expo export --platform web",
    "android:usb-api": "adb reverse tcp:8000 tcp:8000",
    "windows:firewall-api": "powershell -ExecutionPolicy Bypass -File ./scripts/allow-port-8000-windows.ps1",
    "verify:api": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-local-api.ps1"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.59.16",
    "axios": "^1.7.9",
    "axios-retry": "^4.1.0",
    "expo": "~54.0.33",
    "expo-application": "~7.0.8",
    "expo-background-fetch": "~14.0.9",
    "expo-battery": "~10.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-cellular": "~8.0.8",
    "expo-crypto": "~15.0.8",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-localization": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-sensors": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-speech-recognition": "^3.1.2",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-updates": "~29.0.16",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "babel-preset-expo": "~54.0.10"
  }
}
