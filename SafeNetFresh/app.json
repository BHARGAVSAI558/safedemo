{
  "expo": {
    "name": "SafeNet",
    "slug": "safenet-devtrails-2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "safenet",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A56DB"
    },
    "android": {
      "package": "com.alphanexus.safenet",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A56DB"
      },
      "usesCleartextTraffic": true
    },
    "ios": {
      "bundleIdentifier": "com.alphanexus.safenet",
      "supportsTablet": false
    },
    "extra": {
      "BACKEND_URL": "https://safenet-api-y4se.onrender.com",
      "BACKEND_URL_DEV": "remote",
      "DEMO_MODE": true,
      "eas": {
        "projectId": "safenet-devtrails-2026"
      }
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
