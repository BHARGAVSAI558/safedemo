# Copy these into Railway → your service → Variables tab.
# Replace placeholder values before deploying to production.

DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@HOST:5432/railway
JWT_SECRET=safenet-prod-secret-change-this-2026
ADMIN_JWT_SECRET=safenet-admin-prod-secret-2026
ALLOWED_ORIGINS=*
DEMO_MODE=true

# Optional — leave blank to disable
REDIS_URL=
MONGODB_URI=
OPENWEATHER_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
